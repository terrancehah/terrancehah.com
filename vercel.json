{
    "cleanUrls": true,
    "functions": {
        "api/index.py": {
            "excludeFiles": "{public/**,playground/**,articles/**,projects/**,dist/**,src/**,.git/**,*.html,*.mp4,*.mov,*.jpg,*.jpeg,*.png,*.gif,*.webp,*.JPG,*.glb}"
        }
    },
    "rewrites": [
        {
            "source": "/projects/persona",
            "destination": "/api"
        },
        {
            "source": "/projects/persona/",
            "destination": "/api"
        }
    ]
}